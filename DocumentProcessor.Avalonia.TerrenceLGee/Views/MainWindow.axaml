<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DocumentProcessor.Avalonia.TerrenceLGee.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DocumentProcessor.Avalonia.TerrenceLGee.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Width="1200"
        Height="800"
        TransparencyLevelHint="Mica"
        RequestedThemeVariant="Dark"
        Background="Transparent"
        Icon="/Assets/contacts.png"
        Title="Document Processor">
    <Window.Styles>
		<Style Selector="Window">
			<Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
        </Style>
    </Window.Styles>

    <Border Background="#CC1E1E1E">
		<ContentControl Content="{Binding CurrentView}"/>
    </Border>

</Window>
